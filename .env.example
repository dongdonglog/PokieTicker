# AI provider: anthropic | openai_compatible
AI_PROVIDER=anthropic

# Market data provider: polygon | ashare
MARKET_DATA_PROVIDER=polygon

# Polygon.io API key (free tier available)
# Sign up at: https://polygon.io/
POLYGON_API_KEY=your_polygon_api_key_here

# Anthropic API key (for Claude AI analysis)
# Sign up at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI-compatible API settings (for self-hosted or third-party compatible endpoints)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini

# Tushare token (for A-share market data)
# Sign up at: https://tushare.pro/
TUSHARE_TOKEN=your_tushare_token_here
